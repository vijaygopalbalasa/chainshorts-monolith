# Required for validate/create/publish scripts
KEYPAIR_PATH=/absolute/path/to/publisher-keypair.json

# Required for validate and create:release
ANDROID_TOOLS_DIR=/Users/you/Library/Android/sdk/build-tools/35.0.0

# Required for publish scripts (mainnet-beta recommended)
RPC_URL=https://api.mainnet-beta.solana.com

# Optional
PRIORITY_FEE_LAMPORTS=500000
ALPHA_SUBMISSION=0
