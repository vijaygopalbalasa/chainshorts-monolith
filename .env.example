# Chainshorts — Environment Variables
# Copy this to .env and fill in your values

# Database
DATABASE_URL=postgresql://user:password@host:5432/chainshorts

# Solana
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
SKR_MINT=SKRbvo6Gf7GondiT3BbTfuRDPqLWei4j2Qy2NPGZhW3
PLATFORM_WALLET=YOUR_PLATFORM_WALLET_ADDRESS
PLATFORM_WALLET_SECRET=YOUR_BASE58_PRIVATE_KEY

# Auth / API
ADMIN_TOKEN=your-secure-admin-token
NODE_ENV=production
TRUST_PROXY=1

# AI Models (OpenRouter)
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_MODEL_PRIMARY=google/gemini-2.5-pro
OPENROUTER_MODEL_FALLBACK=moonshotai/kimi-k2.5

# Helius Webhook
HELIUS_WEBHOOK_SECRET=your-webhook-secret

# Jupiter
JUPITER_API_KEY=your-jupiter-api-key

# Mobile (Expo)
EXPO_PUBLIC_API_BASE_URL=https://api.chainshorts.live
EXPO_PUBLIC_SOLANA_RPC_URL=https://api.chainshorts.live/v1/rpc
EXPO_PUBLIC_SOLANA_CHAIN=mainnet-beta
EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id

# Notifications (Expo)
EXPO_TOKEN=your-expo-token

# Push
ENABLE_PUSH_NOTIFICATIONS=1
